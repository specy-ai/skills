}

command RecordConsultation {
    satisfies []
    correlationId    : uuid
    petId            : uuid
    petOwnerId       : uuid
    clinicId         : uuid
    veterinarianId   : uuid
    consultationDate : date
    reasonForVisit   : string
    diagnosis        : string optional
    treatment        : string optional
    notes            : string optional
}

command UpdateConsultationNotes {
    satisfies []
    correlationId  : uuid
    consultationId : uuid
    diagnosis      : string optional
    treatment      : string optional
    notes          : string optional
}

command GenerateMedicalRecordShare {
    satisfies []
    correlationId : uuid
    petId         : uuid
    petOwnerId    : uuid
    shareFormat   : string
    ownerConsent  : boolean
    expiresAt     : datetime
}

// =============================================================================
// Events — Pet Health Record
// =============================================================================

event PetOwnerRegistered {
    satisfies []
    petOwnerId : uuid
    email      : string
    createdAt  : datetime
}

event PetOwnerProfileUpdated {
    satisfies []
    petOwnerId : uuid
    updatedAt  : datetime
}

event DataErasureRequested {
    satisfies []
