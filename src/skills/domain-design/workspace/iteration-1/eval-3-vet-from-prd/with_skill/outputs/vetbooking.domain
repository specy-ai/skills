}


// #############################################################################
//  CLINIC DISCOVERY CONTEXT
// #############################################################################

module ClinicDiscovery
uses module ClinicManagement

// =============================================================================
// Enums
// =============================================================================

enum ReviewStatus {
    pending
    published
    flagged
}

// =============================================================================
// Entities — Clinic Discovery
// =============================================================================

entity ClinicSearchResult :: "A projected view of a clinic for search results" {
    satisfies []
    identifier id : UUID
    fields {
        clinicId          : uuid
        name              : string
        address           : Address
        distance          : decimal optional
        averageRating     : decimal optional
        totalReviews      : int default("0")
        specialties       : list<Specialty>
        animalTypes       : list<AnimalType>
        nextAvailableSlot : datetime optional
    }

    operations {
        "Search nearby clinics" on SearchNearbyClinics {
            emits ClinicSearchPerformed {
                searchId      = generateId()
                location      = searchNearbyClinics.location
                radiusKm      = searchNearbyClinics.radiusKm
                animalType    = searchNearbyClinics.animalType
                specialty     = searchNearbyClinics.specialty
                resultCount   = results.size()
                searchedAt    = now()
            }
        }
    }
}

entity Review :: "A rating and review left by a pet owner for a clinic after a completed visit" {
    satisfies []
    identifier id : UUID
    fields {
        petOwnerId    : uuid immutable
        clinicId      : uuid immutable
        appointmentId : uuid immutable
        rating        : Rating
        text          : string optional maxLength(2000)
        status        : ReviewStatus default("pending")
        clinicResponse : string optional
        createdAt     : datetime immutable
        updatedAt     : datetime
    }

    invariants {
        reviewRequiresCompletedVisit :: "Reviews can only be submitted after a confirmed and completed appointment" {
            appointmentId is defined
        }
        ratingRequired :: "A review must include a rating" {
            rating is defined
        }
    }

    operations {
        "Submit review" on SubmitReview {
            policy visitMustBeCompleted :: "Review can only be submitted for a completed appointment" {
                // Verified via cross-context query to AppointmentBooking
            }

            creates Review {
                petOwnerId    = submitReview.petOwnerId
                clinicId      = submitReview.clinicId
                appointmentId = submitReview.appointmentId
                rating        = submitReview.rating
                text          = submitReview.text
                status        = pending
                createdAt     = now()
                updatedAt     = now()
            }

            emits ReviewSubmitted {
                reviewId      = Review.id
                petOwnerId    = Review.petOwnerId
                clinicId      = Review.clinicId
                appointmentId = Review.appointmentId
                rating        = Review.rating
                submittedAt   = Review.createdAt
            }

            emits error ReviewSubmissionFailed {
                correlationId : uuid
                petOwnerId    : uuid
                appointmentId : uuid
                reason        : string
            }
        }

        "Publish review" on PublishReview {
            resolves Review from publishReview.reviewId

            policy reviewMustBePending(Review) :: "Only pending reviews can be published" {
                Review.status = pending
            }

            sets Review {
                status    = published
                updatedAt = now()
            }

            emits ReviewPublished {
                reviewId = Review.id
                clinicId = Review.clinicId
                rating   = Review.rating
                publishedAt = now()
            }
        }

        "Flag review" on FlagReview {
            resolves Review from flagReview.reviewId

            sets Review {
                status    = flagged
                updatedAt = now()
            }

            emits ReviewFlagged {
                reviewId  = Review.id
                clinicId  = Review.clinicId
                flaggedAt = now()
                reason    = flagReview.reason
            }
        }

        "Respond to review" on RespondToReview {
            resolves Review from respondToReview.reviewId

            policy reviewMustBePublished(Review) :: "Only published reviews can receive a response" {
                Review.status = published
            }

            sets Review {
                clinicResponse = respondToReview.responseText
                updatedAt      = now()
            }

            emits ReviewResponseAdded {
                reviewId     = Review.id
                clinicId     = Review.clinicId
                respondedAt  = now()
            }
        }
    }

    transitions {
        [*] --> pending on "Submit review"
        pending --> published on "Publish review"
        pending --> flagged on "Flag review"
        published --> flagged on "Flag review"
    }
}

// =============================================================================
// Reactions — Clinic Discovery
// =============================================================================

reaction updateClinicRatingOnReviewPublished :: "When a review is published, update the clinic's average rating" {
    satisfies []
    triggered-by ReviewPublished
    guard { true }
    effects UpdateClinicRating {
        clinicId = ReviewPublished.clinicId
    }
}

// =============================================================================
// Commands — Clinic Discovery
// =============================================================================

command SearchNearbyClinics {
    satisfies []
    correlationId : uuid
    location      : GeoCoordinate
    radiusKm      : decimal default("10")
    animalType    : AnimalType optional
    specialty     : string optional
}

command SubmitReview {
    satisfies []
    correlationId : uuid
    petOwnerId    : uuid
    clinicId      : uuid
    appointmentId : uuid
    rating        : Rating
    text          : string optional
}

command PublishReview {
    satisfies []
    correlationId : uuid
    reviewId      : uuid
}

command FlagReview {
    satisfies []
    correlationId : uuid
    reviewId      : uuid
    reason        : string
}

command RespondToReview {
    satisfies []
    correlationId : uuid
    reviewId      : uuid
    responseText  : string
}

command UpdateClinicRating {
    satisfies []
    correlationId : uuid
    clinicId      : uuid
}

// =============================================================================
// Events — Clinic Discovery
// =============================================================================

event ClinicSearchPerformed {
    satisfies []
    searchId    : uuid
    location    : GeoCoordinate
    radiusKm    : decimal
    animalType  : AnimalType optional
    specialty   : string optional
    resultCount : int
    searchedAt  : datetime
}

event ReviewSubmitted {
    satisfies []
    reviewId      : uuid
    petOwnerId    : uuid
    clinicId      : uuid
    appointmentId : uuid
    rating        : Rating
    submittedAt   : datetime
}

event ReviewPublished {
    satisfies []
    reviewId    : uuid
    clinicId    : uuid
    rating      : Rating
    publishedAt : datetime
}

event ReviewFlagged {
    satisfies []
    reviewId  : uuid
    clinicId  : uuid
    flaggedAt : datetime
    reason    : string
}

event ReviewResponseAdded {
    satisfies []
    reviewId    : uuid
    clinicId    : uuid
    respondedAt : datetime
}

error event ReviewSubmissionFailed {
    satisfies []
    correlationId : uuid
    petOwnerId    : uuid
    appointmentId : uuid
    reason        : string
}


// #############################################################################
//  NOTIFICATION CONTEXT
// #############################################################################

module Notification

// =============================================================================
// Enums
// =============================================================================

enum NotificationChannel {
    sms
    push
    email
}

enum NotificationType {
    appointmentConfirmation
    appointmentReminder48h
    appointmentReminder2h
    appointmentCancellation
    bookingNotification
    cancellationNotification
    vaccinationReminder
}

enum NotificationStatus {
    scheduled
    sent
    failed
    cancelled
}

// =============================================================================
// Value Types — Notification
// =============================================================================

value NotificationContent :: "The content payload of a notification" {
    fields {
        subject : string optional
        body    : string
        data    : string optional
    }
}

// =============================================================================
// Entities — Notification
// =============================================================================

entity NotificationRecord :: "A record of a notification sent or scheduled" {
    satisfies []
    identifier id : UUID
    fields {
        recipientId   : uuid
        channel       : NotificationChannel
        type          : NotificationType
        content       : NotificationContent
        status        : NotificationStatus default("scheduled")
        scheduledAt   : datetime
        sentAt        : datetime optional
        failureReason : string optional
        createdAt     : datetime immutable
    }

    invariants {
        sentNotificationHasTimestamp :: "A sent notification must have a sent-at timestamp" {
            if status = sent { sentAt is defined }
        }
        failedNotificationHasReason :: "A failed notification must have a failure reason" {
            if status = failed { failureReason is defined }
        }
    }

    operations {
        "Schedule notification" on ScheduleNotification {
            creates NotificationRecord {
                recipientId = scheduleNotification.recipientId
                channel     = scheduleNotification.channel
                type        = scheduleNotification.type
                content     = scheduleNotification.content
                status      = scheduled
                scheduledAt = scheduleNotification.scheduledAt
                createdAt   = now()
            }

            emits NotificationScheduled {
                notificationId = NotificationRecord.id
                recipientId    = NotificationRecord.recipientId
                channel        = NotificationRecord.channel
                type           = NotificationRecord.type
                scheduledAt    = NotificationRecord.scheduledAt
            }
        }

        "Send notification" on SendNotification {
            resolves NotificationRecord from sendNotification.notificationId

            policy notificationMustBeScheduled(NotificationRecord) :: "Only scheduled notifications can be sent" {
                NotificationRecord.status = scheduled
            }

            sets NotificationRecord {
                status = sent
                sentAt = now()
            }

            emits NotificationSent {
                notificationId = NotificationRecord.id
                recipientId    = NotificationRecord.recipientId
                channel        = NotificationRecord.channel
                type           = NotificationRecord.type
                sentAt         = now()
            }

            emits error NotificationDeliveryFailed {
                notificationId : uuid
                recipientId    : uuid
                channel        : NotificationChannel
                reason         : string
                failedAt       : datetime
            }
        }

        "Mark notification failed" on MarkNotificationFailed {
            resolves NotificationRecord from markNotificationFailed.notificationId

            sets NotificationRecord {
                status        = failed
                failureReason = markNotificationFailed.reason
            }

            emits NotificationFailed {
                notificationId = NotificationRecord.id
                recipientId    = NotificationRecord.recipientId
                reason         = markNotificationFailed.reason
                failedAt       = now()
            }
        }

        "Cancel notification" on CancelNotification {
            resolves NotificationRecord from cancelNotification.notificationId

            policy notificationMustBeScheduled(NotificationRecord) :: "Only scheduled notifications can be cancelled" {
                NotificationRecord.status = scheduled
            }

            sets NotificationRecord {
                status = cancelled
            }

            emits NotificationCancelled {
                notificationId = NotificationRecord.id
                recipientId    = NotificationRecord.recipientId
                cancelledAt    = now()
            }
        }
    }

    transitions {
        [*] --> scheduled on "Schedule notification"
        scheduled --> sent on "Send notification"
        scheduled --> failed on "Mark notification failed"
        scheduled --> cancelled on "Cancel notification"
    }
}

// =============================================================================
// Infrastructure Services — Notification
// =============================================================================

service SmsGateway :: "Adapter to external SMS provider for sending text messages" {
    satisfies []
    operations {
        sendSms(phoneNumber: string, message: string): void :: "Send an SMS message" {
        }
    }
}

service PushNotificationGateway :: "Adapter to push notification service (APNs/FCM)" {
    satisfies []
    operations {
        sendPush(deviceToken: string, title: string, body: string, data: string): void :: "Send a push notification" {
        }
    }
}

service EmailGateway :: "Adapter to email sending service" {
    satisfies []
    operations {
        sendEmail(toAddress: string, subject: string, body: string): void :: "Send an email" {
        }
    }
}

// =============================================================================
// Commands — Notification
// =============================================================================

command ScheduleNotification {
    satisfies []
    correlationId : uuid
    recipientId   : uuid
    channel       : NotificationChannel
    type          : NotificationType
    content       : NotificationContent
    scheduledAt   : datetime
}

command SendNotification {
    satisfies []
    correlationId  : uuid
    notificationId : uuid
}

command MarkNotificationFailed {
    satisfies []
    correlationId  : uuid
    notificationId : uuid
    reason         : string
}

command CancelNotification {
    satisfies []
    correlationId  : uuid
    notificationId : uuid
}

command SendBookingNotification {
    satisfies []
    correlationId : uuid
    clinicId      : uuid
    appointmentId : uuid
    petOwnerId    : uuid
}

command SendCancellationNotification {
    satisfies []
    correlationId : uuid
    clinicId      : uuid
    appointmentId : uuid
}

command ScheduleAppointmentReminders {
    satisfies []
    correlationId : uuid
    appointmentId : uuid
    petOwnerId    : uuid
    scheduledDate : date
    scheduledTime : TimeSlot
}

command SendAppointmentReminder {
    satisfies []
    correlationId : uuid
    appointmentId : uuid
    petOwnerId    : uuid
    clinicId      : uuid
    reminderType  : string
}

command SendVaccinationReminder {
    satisfies []
    correlationId : uuid
    petId         : uuid
    petOwnerId    : uuid
    vaccineName   : string
    dueDate       : date
}

// =============================================================================
// Events — Notification
// =============================================================================

event NotificationScheduled {
    satisfies []
    notificationId : uuid
    recipientId    : uuid
    channel        : NotificationChannel
    type           : NotificationType
    scheduledAt    : datetime
}

event NotificationSent {
    satisfies []
    notificationId : uuid
    recipientId    : uuid
    channel        : NotificationChannel
    type           : NotificationType
    sentAt         : datetime
}

event NotificationFailed {
    satisfies []
    notificationId : uuid
    recipientId    : uuid
    reason         : string
    failedAt       : datetime
}

event NotificationCancelled {
    satisfies []
    notificationId : uuid
    recipientId    : uuid
    cancelledAt    : datetime
}

error event NotificationDeliveryFailed {
    satisfies []
    notificationId : uuid
    recipientId    : uuid
    channel        : NotificationChannel
    reason         : string
    failedAt       : datetime
}


// #############################################################################
//  CONTEXT MAP
// #############################################################################

// AppointmentBooking is the core context — it consumes from ClinicManagement
// (slot availability) and PetHealthRecord (pet/owner identity), and drives
// Notification (reminders, confirmations).

// ClinicManagement ──OHS──> AppointmentBooking (C/S — booking consumes slot availability)
// ClinicManagement ──OHS──> ClinicDiscovery (C/S — search consumes clinic profiles)
// PetHealthRecord  ──OHS──> AppointmentBooking (C/S — booking consumes pet/owner data)
// AppointmentBooking ──OHS──> PetHealthRecord (events — completed appointments feed consultation records)
// AppointmentBooking ──OHS──> Notification (C/S — booking drives reminder scheduling)
// ClinicDiscovery ──ACL──> AppointmentBooking (verifies completed visits for reviews)
// Notification ──ACL──> SmsGateway, PushNotificationGateway, EmailGateway (infrastructure adapters)


// #############################################################################
//  AGREEMENTS
// #############################################################################

agreement SlotBookingConsistency :: "An availability slot marked as booked must correspond to exactly one confirmed appointment, and vice versa" {
    satisfies []
    participants ClinicAggregate, AppointmentAggregate
    predicate {
        for every AvailabilitySlot where status = booked:
            there exists exactly one Appointment where slotId = AvailabilitySlot.id and status in { confirmed, completed }
        and
        for every Appointment where status = confirmed:
            there exists exactly one AvailabilitySlot where id = Appointment.slotId and status = booked
    }

    reconciliation SlotBookingReconciliation :: "Detect and repair slot-appointment mismatches" {
        trigger event AppointmentCancelled, AppointmentCompleted, AvailabilitySlotBooked, AvailabilitySlotFreed
        detection query-based
        compensation {
            // If slot is booked but no confirmed appointment exists → free the slot
            // If appointment is confirmed but slot is not booked → cancel the appointment
        }
        escalation {
            step 1 {
                trigger-condition "compensation failed"
                action alert
            }
        }
    }
}
