// Events
// =============================================================================

// source: driver-management.model.md
event DriverRegistered {
    fields {
        driverId : uuid
        fullName : FullName
        email : EmailAddress
        phone : PhoneNumber
        registeredAt : datetime
    }
}

// source: driver-management.model.md
event IdentityDocumentUploaded {
    fields {
        driverId : uuid
        documentId : uuid
        documentType : DocumentType
        uploadedAt : datetime
    }
}

// source: driver-management.model.md
event BackgroundCheckCompleted {
    fields {
        driverId : uuid
        checkId : string
        result : BackgroundCheckResult
        completedAt : datetime
    }
}

// source: driver-management.model.md
event BackgroundCheckFailed {
    fields {
        driverId : uuid
