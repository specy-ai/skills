        timestamp : datetime
    }
}

// source: driver-management.model.md
event RatingSubmitted {
    fields {
        driverId : uuid
        rideId : uuid
        rating : Rating
        newAverageRating : AverageRating
        totalRidesCompleted : int
        submittedAt : datetime
    }
}

// source: driver-management.model.md
event DriverSuspended {
    fields {
        driverId : uuid
        reason : string
        suspendedAt : datetime
    }
}

// source: driver-management.model.md
event AppealSubmitted {
    fields {
        driverId : uuid
        appeal : AppealDetails
    }
}

// source: driver-management.model.md
event AppealResolved {
    fields {
        driverId : uuid
        resolution : AppealResolution
        resolvedAt : datetime
    }
}

// source: driver-management.model.md
event DriverNotified {
    fields {
        driverId : uuid
        subject : string
        channel : NotificationChannel
        sentAt : datetime
    }
}

// source: driver-management.model.md
event DocumentExpired {
    fields {
        driverId : uuid
        documentId : uuid optional
        vehicleId : uuid optional
        expiryType : string
        expiredAt : datetime
    }
}
