command UploadIdentityDocument {
    fields {
        driverId : uuid
        documentType : DocumentType
        documentNumber : string
        fileUrl : string
        expiresAt : datetime
    }
}

// source: driver-management.model.md
command CompleteBackgroundCheck {
    fields {
        driverId : uuid
        backgroundCheckResult : BackgroundCheckResult
        checkId : string
    }
}

// source: driver-management.model.md
command RegisterVehicle {
    fields {
        driverId : uuid
        details : VehicleDetails
    }
}

// source: driver-management.model.md
command RecordVehicleInspection {
    fields {
        driverId : uuid
        vehicleId : uuid
        result : InspectionResult
    }
}

// source: driver-management.model.md
command GoOnline {
    fields {
        driverId : uuid
    }
}

// source: driver-management.model.md
command GoOffline {
    fields {
        driverId : uuid
    }
}

// source: driver-management.model.md
command TimeoutInactiveDriver {
    fields {
        driverId : uuid
