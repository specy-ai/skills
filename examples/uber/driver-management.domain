module DriverManagement
uses module RideManagement  // consumes RideCompleted events for rating workflows
uses module GeolocationRouting // consumes location updates for inactivity detection

// =============================================================================
// Enums
// =============================================================================

// source: driver-management.model.md
enum VerificationState {
    pendingVerification
    verified
    rejected
    suspended
    appealInReview
    permanentlySuspended
}

// source: driver-management.model.md
enum AvailabilityState {
    offline
    online
}

// source: driver-management.model.md
enum DocumentType {
    driversLicense
    passport
    nationalId
}

// source: driver-management.model.md
enum BackgroundCheckResult {
    clear
    failed
}

// source: driver-management.model.md
enum OfflineReason {
    voluntary
    inactivityTimeout
    suspension
}

// source: driver-management.model.md
enum AppealOutcome {
    reinstated
    permanentlySuspended
}

// source: driver-management.model.md
enum NotificationChannel {
    email
    sms
    push
}

// =============================================================================
// Value Objects
// =============================================================================

// source: driver-management.model.md
value EmailAddress {
    fields {
        value : string
    }
    invariants {
        validEmailFormat :: "Value must match a valid email pattern" {
            // UNCLEAR: email pattern validation not expressible as simple expression
        }
    }
}

// source: driver-management.model.md
value PhoneNumber {
    fields {
        countryCode : string
        number : string
    }
    invariants {
        validPhoneFormat :: "Country code must be valid ISO dial code and number must contain only digits" {
            // UNCLEAR: phone format validation not expressible as simple expression
        }
    }
}

// source: driver-management.model.md
value FullName {
    fields {
        firstName : string
        lastName : string
    }
    invariants {
        nonBlankName :: "Both firstName and lastName must be non-blank" {
            size(firstName) > 0 and size(lastName) > 0
        }
    }
}

// source: driver-management.model.md
value Rating {
    fields {
        value : int
    }
    invariants {
        ratingRange :: "Rating value must be between 1 and 5" {
            value >= 1 and value <= 5
        }
    }
}

// source: driver-management.model.md
value AverageRating {
    fields {
        value : decimal
        totalRatings : int
        ratingSum : int
    }
    invariants {
        nonNegativeTotals :: "Total ratings and rating sum must be non-negative" {
            totalRatings >= 0 and ratingSum >= 0
        }
        // UNCLEAR: ConsistentAverage — totalRatings == 0 OR value == ratingSum / totalRatings (division not expressible)
    }
}

// source: driver-management.model.md
value Address {
    fields {
        street : string
        city : string
        state : string
        zipCode : string
        country : string
    }
    invariants {
        nonBlankRequiredFields :: "Street, city, zipCode, and country must be non-blank" {
            size(street) > 0 and size(city) > 0 and size(zipCode) > 0 and size(country) > 0
        }
    }
}

// source: driver-management.model.md
value VehicleDetails {
    fields {
        make : string
        model : string
        year : int
        color : string
        licensePlate : string
    }
    invariants {
        validYear :: "Year must be between 1900 and current year + 1" {
            year >= 1900
        }
        nonBlankPlate :: "License plate must be non-blank" {
            size(licensePlate) > 0
        }
    }
}

// source: driver-management.model.md
value InspectionResult {
    fields {
        passed : boolean
        inspectedAt : datetime
        expiresAt : datetime
        notes : string optional
    }
    invariants {
        expiryAfterInspection :: "Expiry must be after inspection date" {
            expiresAt > inspectedAt
        }
    }
}

// source: driver-management.model.md
value AppealDetails {
    fields {
        reason : string
        submittedAt : datetime
        supportingDocumentIds : list<string> optional
    }
    invariants {
        nonBlankReason :: "Reason must be non-blank" {
            size(reason) > 0
        }
    }
}

// source: driver-management.model.md
value AppealResolution {
    fields {
        outcome : AppealOutcome
        resolvedBy : string
        resolvedAt : datetime
        justification : string
    }
    invariants {
        nonBlankJustification :: "Justification must be non-blank" {
            size(justification) > 0
        }
    }
}

