#!/usr/bin/env bash
# Pre-commit hook: ensures generated dist/ files are up to date with src/skills/
#
# Rebuilds from src/skills/ templates and checks for drift. If the generated files
# differ from what's staged, the commit is blocked.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
BUILD_SCRIPT="$REPO_ROOT/src/skills/build.sh"

if [[ ! -x "$BUILD_SCRIPT" ]]; then
  echo "pre-commit: build script not found or not executable: $BUILD_SCRIPT"
  exit 1
fi

# Run the build
"$BUILD_SCRIPT" > /dev/null 2>&1

# Check all SKILL.md files and runtime files in dist/skills/ for drift
DIRTY=()
for skill_dir in "$REPO_ROOT"/dist/skills/*/; do
  skill=$(basename "$skill_dir")
  # Check SKILL.md
  if [[ -f "$skill_dir/SKILL.md" ]]; then
    if ! git diff --quiet -- "$skill_dir/SKILL.md" 2>/dev/null; then
      DIRTY+=("dist/skills/$skill/SKILL.md")
    fi
  fi
  # Check runtime files (heuristics, grammars, grammar, references)
  for subdir in heuristics grammars grammar references; do
    if [[ -d "$skill_dir/$subdir" ]]; then
      for f in "$skill_dir/$subdir"/*; do
        [[ -f "$f" ]] || continue
        if ! git diff --quiet -- "$f" 2>/dev/null; then
          DIRTY+=("dist/skills/$skill/$subdir/$(basename "$f")")
        fi
      done
    fi
  done
done

if [[ ${#DIRTY[@]} -gt 0 ]]; then
  echo "pre-commit: generated files in dist/ are out of date with src/skills/ templates."
  echo ""
  echo "The following files need to be regenerated and staged:"
  for f in "${DIRTY[@]}"; do
    echo "  - $f"
  done
  echo ""
  echo "Run: src/skills/build.sh && git add dist/"
  exit 1
fi
