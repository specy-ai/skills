#!/usr/bin/env bash
# Pre-commit hook: ensures generated SKILL.md files are up to date with src/
#
# Rebuilds from src/ templates and checks for drift. If the generated files
# differ from what's staged, the commit is blocked.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
BUILD_SCRIPT="$REPO_ROOT/skills/src/build.sh"

if [[ ! -x "$BUILD_SCRIPT" ]]; then
  echo "pre-commit: build script not found or not executable: $BUILD_SCRIPT"
  exit 1
fi

# Run the build
"$BUILD_SCRIPT" > /dev/null 2>&1

# Check if any generated files changed
GENERATED_FILES=(
  "skills/distill/SKILL.md"
  "skills/dialogue/SKILL.md"
  "skills/spec/SKILL.md"
  "skills/distill/heuristics/java-spring.md"
  "skills/distill/heuristics/typescript-nestjs.md"
  "skills/distill/heuristics/clojure.md"
  "skills/distill/grammars/specy.ebnf"
)

DIRTY=()
for f in "${GENERATED_FILES[@]}"; do
  if ! git diff --quiet -- "$REPO_ROOT/$f" 2>/dev/null; then
    DIRTY+=("$f")
  fi
done

if [[ ${#DIRTY[@]} -gt 0 ]]; then
  echo "pre-commit: generated files are out of date with src/ templates."
  echo ""
  echo "The following files need to be regenerated and staged:"
  for f in "${DIRTY[@]}"; do
    echo "  - $f"
  done
  echo ""
  echo "Run: skills/src/build.sh && git add ${DIRTY[*]}"
  exit 1
fi
